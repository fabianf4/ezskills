{
  "name": "@fabianf4/ezskills",
  "version": "0.3.1",
  "description": "TUI to install and uninstall skills for OpenCode and OpenClaw",
  "type": "module",
  "bin": {
    "ezskills": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist/index.js",
    "dist/index.js.map",
    "catalog",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "build:index": "tsx scripts/build-index.ts",
    "build": "rm -rf dist && esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/index.js --alias:react-devtools-core=./scripts/react-devtools-core-stub.js --banner:js=\"const require = (await import('node:module')).createRequire(import.meta.url);\" --sourcemap && chmod +x dist/index.js",
    "postbuild": "chmod +x dist/index.js",
    "prepublishOnly": "pnpm test && pnpm typecheck && pnpm build:index && pnpm build",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "tui",
    "skills",
    "opencode",
    "openclaw"
  ],
  "license": "MIT",
  "author": "fabianf4",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fabianf4/ezskills.git"
  },
  "bugs": {
    "url": "https://github.com/fabianf4/ezskills/issues"
  },
  "homepage": "https://github.com/fabianf4/ezskills#readme",
  "engines": {
    "node": ">=20",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.9.0",
  "dependencies": {
    "chalk": "^5.3.0",
    "ink": "^5.0.1",
    "memfs": "^4.14.0",
    "react": "^18.3.1",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-test-renderer": "^18.3.0",
    "@vitest/coverage-v8": "^2.1.8",
    "esbuild": "^0.24.0",
    "ink-testing-library": "^4.0.0",
    "react-test-renderer": "^18.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
